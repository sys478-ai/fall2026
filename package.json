{
  "name": "csci344-course-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "zip": "bash ./public/course-files/build/build.sh",
    "stylelint": "stylelint \"**/*.css\" --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{md,mdx,html,css,js,jsx,ts,tsx,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{md,mdx,html,css,js,jsx,ts,tsx,json,yml,yaml}\"",
    "export": "next build",
    "deploy": "npm run build && touch out/.nojekyll"
  },
  "dependencies": {
    "@codemirror/lang-css": "*",
    "@codemirror/lang-html": "*",
    "@codemirror/lang-javascript": "*",
    "@codemirror/theme-one-dark": "*",
    "@heroicons/react": "*",
    "@tailwindcss/typography": "*",
    "@uiw/react-codemirror": "*",
    "canvas-confetti": "*",
    "clsx": "*",
    "date-fns": "*",
    "fs": "*",
    "gray-matter": "*",
    "highlight.js": "*",
    "jszip": "*",
    "next": "*",
    "react": "*",
    "react-dom": "*",
    "rehype": "*",
    "rehype-raw": "*",
    "rehype-stringify": "*",
    "remark": "*",
    "remark-gfm": "*",
    "remark-highlight.js": "*",
    "remark-html": "*",
    "remark-parse": "*",
    "remark-rehype": "*",
    "remark-smartypants": "*",
    "unified": "*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "*",
    "@tailwindcss/postcss": "*",
    "@types/canvas-confetti": "*",
    "@types/jszip": "*",
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "eslint": "*",
    "eslint-config-next": "*",
    "html2canvas": "*",
    "prettier": "^3.8.3",
    "stylelint": "*",
    "stylelint-config-recommended": "*",
    "stylelint-config-tailwindcss": "*",
    "tailwindcss": "*",
    "typescript": "*"
  }
}
